# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://autopentest:autopentest@postgres:5432/autopentest
DATABASE_URL_SYNC=postgresql://autopentest:autopentest@postgres:5432/autopentest

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── AI / Models ───────────────────────────────────────────────────────────────
# Path to .gguf model files (mounted into container)
MODEL_PATH=/models
# Default model filename — drop your .gguf file here
DEFAULT_MODEL_FILE=model.gguf
# Ollama host (alternative to llama.cpp direct)
OLLAMA_HOST=http://ollama:11434
# Embedding model for pgvector (via Ollama)
EMBEDDING_MODEL=nomic-embed-text

# ─── Cloud AI Provider API Keys (optional — leave blank to use local models) ───
# Anthropic — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI / ChatGPT — https://platform.openai.com/
OPENAI_API_KEY=
# Google Gemini — https://aistudio.google.com/
GEMINI_API_KEY=
# Default model name per provider (can be overridden per AIModelConfig in DB)
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6
OPENAI_DEFAULT_MODEL=gpt-4o
GEMINI_DEFAULT_MODEL=gemini-2.0-flash

# ─── Scan Settings ─────────────────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_SECONDS=3600

# ─── Storage ───────────────────────────────────────────────────────────────────
EVIDENCE_STORAGE_PATH=/data/evidence
REPORT_OUTPUT_PATH=/data/reports

# ─── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── MFA (optional) ────────────────────────────────────────────────────────────
# TOTP issuer name shown in authenticator apps
MFA_ISSUER=AutoPentest

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
LOGIN_RATE_LIMIT=10
LOGIN_RATE_WINDOW_SECONDS=60

# ─── Docker ────────────────────────────────────────────────────────────────────
# Network used for sandbox containers
SANDBOX_NETWORK=autopentest_scan_net
